
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  password      String
  role          String
  createdAt     DateTime        @default(now())
  websites      Website[]       @relation("ClientWebsites")
  issues        Issue[]         @relation("CreatedIssues")
  comments      Comment[]       @relation("UserComments")
  events        TimelineEvent[] @relation("UserEvents")
  notifications Notification[]   @relation("UserNotifications")
}

model Website {
  id          String   @id @default(cuid())
  name        String
  url         String
  status      String
  lastChecked DateTime @default(now())
  clientId    String
  client      User     @relation("ClientWebsites", fields: [clientId], references: [id], onDelete: Cascade)
  issues      Issue[]

  @@index([clientId])
  @@index([status])
}

model Issue {
  id          String          @id @default(cuid())
  title       String
  description String
  category    String
  severity    String
  status      String
  websiteId   String
  website     Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdBy   String
  creator     User            @relation("CreatedIssues", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  comments    Comment[]
  events      TimelineEvent[]

  @@index([status])
  @@index([createdBy])
  @@index([websiteId])
  @@index([severity])
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  @@index([issueId])
}

model TimelineEvent {
  id        String   @id @default(cuid())
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  type      String
  oldValue  String?
  newValue  String?
  createdBy String
  creator   User     @relation("UserEvents", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([issueId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}
